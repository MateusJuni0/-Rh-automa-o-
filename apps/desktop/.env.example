# Desktop env vars — copiar para .env e ajustar
# Em dev: ALLOW_DEV_SESSION=1 dispensa auth real (Supabase + JWT)

# Modo dev: aceita qualquer credencial no login sem Supabase
ALLOW_DEV_SESSION=1

# URL do servidor WebSocket (apps/ws). Vazio = modo demo (mock feed sem servidor).
# Em dev: arrancar `pnpm --filter ws start` e usar o porto impresso (default 18792)
VERA_WS_ORIGIN=ws://localhost:18792

# JWT do recrutador (injetado automaticamente via deep link vera:// ao iniciar pelo web).
# Pode ser definido manualmente para testar sem o web app.
# Com ALLOW_DEV_SESSION=1 no servidor WS, usar o sentinel "dev-token".
VERA_ACCESS_TOKEN=dev-token

# UUID da entrevista em curso (injetado automaticamente via deep link vera://).
# Pode ser qualquer UUID não-vazio quando ALLOW_DEV_SESSION=1 (sem verificação de posse real).
VERA_INTERVIEW_ID=00000000-0000-4000-8000-000000000001

# URL do web app (para o atalho "Abrir web" no tray).
VERA_API_ORIGIN=http://localhost:3000
