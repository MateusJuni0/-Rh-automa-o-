# Inventário de env da Vera (ARQUITETURA-INTEGRACAO §3). Valores REAIS vivem em
# .env.enc (sops+age) → decriptado no boot. Este ficheiro é só o mapa de chaves.

# --- Supabase (self-hosted na VPS; local = profile `supabase` do docker-compose.dev.yml) ---
# Sem estas envs a web cai no shim de cookie (auth) + storage mock — dev funciona à mesma.
# ⚠️ Invariante de boot (fail-fast): tens de definir SUPABASE_URL e SUPABASE_ANON_KEY JUNTOS (ou
# nenhum). Só um dos dois → o arranque aborta (config meia-feita cairia em modo mock sem avisar).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Bucket privado por agência (signed URLs). Default de dev: vera-private.
SUPABASE_STORAGE_BUCKET=vera-private
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- LLM via OpenRouter (modelo por slot, trocável na UI) ---
OPENROUTER_API_KEY=
MODEL_EXTRACTOR=
MODEL_ARCHITECT=
MODEL_LIVE=
EMBEDDER_API_KEY=

# --- Conhecimento externo + sourcing ---
EXA_API_KEY=
BRAVE_API_KEY=
APIFY_TOKEN=

# --- Tempo real ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
SONIOX_API_KEY=
STT_PROVIDER=soniox

# --- Ingestão + comunicação ---
TELEGRAM_BOT_TOKEN=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
RESEND_API_KEY=

# --- Calendário (assistente proativo) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- App ---
WS_URL=
NEXT_PUBLIC_WS_URL=
REDIS_URL=
# Autoriza o fallback DEV de sessão (identidade Filipa sem auth real). EXPLÍCITO — sem isto, a app
# em produção sem Supabase Auth ABORTA no arranque (não serve em modo mock por acidente). Em dev
# local sem auth, define ALLOW_DEV_SESSION=1 para poder navegar.
ALLOW_DEV_SESSION=

# --- Tetos de custo (RESILIENCIA-E-FALHAS) ---
INTERVIEW_COST_CAP_USD=
LIVE_SEARCH_MAX_PER_INTERVIEW=
LIVE_SEARCH_COST_CAP_USD=
